# gcp-infra-foundation ルート変数のサンプル
# 実ファイルは terraform.tfvars にコピーして値を埋める（*.tfvars は gitignore 対象）。

project_id         = "fwlm"
region             = "asia-northeast1"
billing_account_id = "000000-000000-000000" # 実際の請求先アカウント ID に置換
budget_amount_jpy  = 10000
alert_email        = "ops@example.com"
github_repository  = "ManatoYamashita/fw-line-meo"

# Places API クォータ上限（Req 7.2）。quota_id は Cloud Quotas の実名。
# バッチが使う日次エンドポイント（検索＋詳細取得）をまとめて上限設定。
# 実名確認: cloudquotas API の quotaInfos（runbook 参照）。空 {} なら上限なし。
places_quota_caps = {
  SearchTextRequestPerDayPerProject   = 1000
  SearchNearbyRequestPerDayPerProject = 1000
  GetPlaceRequestPerDayPerProject     = 1000
}
