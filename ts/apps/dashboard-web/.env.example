# dashboard-web のクライアント公開 env（NEXT_PUBLIC_*）。
# 重要: これらは next build 時にクライアントバンドルへインライン化される値であり、
# Cloud Run のランタイム env 注入では反映されない。デプロイでは必ず Dockerfile の
# build-arg（ARG+ENV・next build 前）として渡すこと（scripts/check-next-public-buildargs.sh が機械検証）。

# dashboard-api（Hono）のベース URL。Bearer トークン付きで業務 API を呼ぶ先。
NEXT_PUBLIC_API_BASE_URL=https://dashboard-api.example.com

# Firebase JS SDK（Google ログイン）初期化用。Identity Platform / Firebase Auth のクライアント設定。
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
